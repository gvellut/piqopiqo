{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "swift-build",
            "type": "shell",
            "command": "swift build && codesign --force --deep --sign - ${workspaceFolder}/GuiApp/.build/debug/GuiApp",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$swiftc"
            ],
            "options": {
                "cwd": "${workspaceFolder}/GuiApp"
            }
        }
    ]
}